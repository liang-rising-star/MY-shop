<!DOCTYPE html><html lang="zh-CN"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>管理后台 - MY-Shop</title>
<link rel="stylesheet" href="/static/css/style.css">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Noto+Sans+SC:wght@300;400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script>
// 页面加载前先获取主题并应用，防止闪烁
(function() {
  var xhr = new XMLHttpRequest();
  xhr.open('GET', '/api/site/theme', false); // 同步请求
  try {
    xhr.send();
    var data = JSON.parse(xhr.responseText);
    var theme = data.theme || 'cyberpunk';
    if (theme !== 'cyberpunk') {
      document.documentElement.className = '';
      document.body.className = 'theme-' + theme;
    }
    window._initialTheme = theme;
  } catch(e) {
    window._initialTheme = 'cyberpunk';
  }
})();
</script>
<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<style>
/* 赛博朋克主题（默认） */
:root{--bg:#0a0e17;--bg2:rgba(15,20,30,0.95);--bg3:rgba(20,28,42,0.9);--border:rgba(0,240,255,0.15);--text:#e0e6ed;--dim:#7a8599;--primary:#00f0ff;--success:#00ff88;--danger:#ff3366;--warning:#ffaa00;--sidebar-w:230px;--header-h:52px;--particle-color:rgba(0,240,255,1);--particle-glow:rgba(0,240,255,0.5);--neon-magenta:#ff00aa;--neon-cyan:#00f0ff;--neon-purple:#7000ff;--neon-green:#00ff88;--neon-red:#ff3366}

/* 简约主题（Home Assistant风格） */
.theme-simple{--bg:#f5f7fa;--bg2:#ffffff;--bg3:#e8ecf1;--border:#d1d5db;--text:#1f2937;--dim:#6b7280;--primary:#3b82f6;--success:#10b981;--danger:#ef4444;--warning:#f59e0b;--particle-color:rgba(59,130,246,1);--particle-glow:rgba(59,130,246,0.3);--neon-magenta:#ec4899;--neon-cyan:#3b82f6;--neon-purple:#8b5cf6;--neon-green:#10b981;--neon-red:#ef4444}

/* 少女主题 */
.theme-cute{--bg:#fff5f8;--bg2:#fff0f5;--bg3:#ffe4ec;--border:#ffb6c1;--text:#d63384;--dim:#c77d9a;--primary:#ff69b4;--success:#ff1493;--danger:#ff69b4;--warning:#ffb7d5;--particle-color:rgba(255,105,180,1);--particle-glow:rgba(255,105,180,0.4);--neon-magenta:#ff69b4;--neon-cyan:#ff69b4;--neon-purple:#da70d6;--neon-green:#ff1493;--neon-red:#ff69b4}

/* 二次元主题 */
.theme-anime{--bg:#1a1a2e;--bg2:rgba(26,26,46,0.95);--bg3:rgba(40,40,70,0.9);--border:rgba(255,200,255,0.2);--text:#e8e0f0;--dim:#a89ec8;--primary:#ff6b9d;--success:#c44dff;--danger:#ff4757;--warning:#ffa502;--particle-color:rgba(255,107,157,1);--particle-glow:rgba(255,107,157,0.5);--neon-magenta:#ff6b9d;--neon-cyan:#4ecdc4;--neon-purple:#c44dff;--neon-green:#7bed9f;--neon-red:#ff6b9d}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Noto Sans SC','Microsoft YaHei',sans-serif;background:var(--bg);color:var(--text);font-size:14px;min-height:100vh;transition:background 0.3s, color 0.3s}
.theme-selector{display:flex;gap:0.5rem;margin-bottom:1rem;padding:1rem;background:var(--bg3);border-radius:8px;border:1px solid var(--border)}
.theme-option{padding:0.6rem 1.2rem;border:2px solid var(--border);border-radius:8px;cursor:pointer;transition:all 0.3s;font-size:0.85rem;display:flex;align-items:center;gap:0.5rem;background:var(--bg2);color:var(--text)}
.theme-option:hover{border-color:var(--primary);transform:translateY(-2px)}
.theme-option.active{border-color:var(--primary);background:var(--primary);color:#fff;box-shadow:0 0 15px rgba(0,0,0,0.2)}
.theme-option i{margin-right:0.3rem}
.theme-preview{width:16px;height:16px;border-radius:50%;display:inline-block}
.theme-cyberpunk{background:linear-gradient(135deg,#00f0ff,#ff00aa)}
.theme-simple-preview{background:linear-gradient(135deg,#3b82f6,#10b981)}
.theme-cute-preview{background:linear-gradient(135deg,#ff69b4,#ff1493)}
.theme-anime-preview{background:linear-gradient(135deg,#ff6b9d,#c44dff)}
#particle-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0}
a{color:var(--primary);text-decoration:none}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
#app{display:flex;min-height:100vh;position:relative;z-index:1}
#sidebar{width:var(--sidebar-w);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;min-height:100vh;backdrop-filter:blur(10px)}
.shdr{display:flex;align-items:center;padding:0.8rem 1rem;border-bottom:1px solid var(--border);gap:0.5rem;background:linear-gradient(90deg,rgba(0,240,255,0.05),transparent)}
.shdr span{font-weight:700;color:var(--primary);font-family:'Orbitron',sans-serif}
.ub{text-align:center;padding:1rem;border-bottom:1px solid var(--border)}
.av{width:44px;height:44px;margin:0 auto 0.5rem;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:600;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--neon-magenta));color:#fff;box-shadow:0 0 20px rgba(0,240,255,0.3)}
.un{font-size:0.85rem;font-weight:600}
.ua{display:flex;justify-content:center;gap:0.8rem;margin-top:0.4rem;font-size:0.8rem}
.ua a{color:var(--dim)}.ua a:hover{color:var(--primary)}
.nav{display:flex;flex-direction:column;flex:1;overflow-y:auto;padding:0.3rem 0;min-height:150px}
.nav a{display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.85rem;color:var(--dim);font-size:0.85rem;cursor:pointer;border-left:3px solid transparent;transition:.15s}
.nav a:hover{color:var(--primary);background:rgba(0,240,255,0.05)}
.nav a.on{color:var(--primary);background:rgba(0,240,255,0.1);border-left-color:var(--primary)}
.nav .divider{display:flex;align-items:center;gap:0.6rem;padding:0.8rem 0.85rem 0.4rem 0.85rem;color:var(--dim);font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;border-top:1px solid var(--border);margin-top:0.5rem}
.nav i{width:16px;text-align:center}
.sf{border-top:1px solid var(--border);padding:0.5rem 0.85rem;font-size:0.75rem;color:var(--dim)}
#main{flex:1;margin-left:var(--sidebar-w);display:flex;flex-direction:column;min-height:100vh}
#hdr{height:var(--header-h);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1rem;background:var(--bg2);gap:1rem;position:sticky;top:0;z-index:50;backdrop-filter:blur(10px)}
#hdr .tl{color:var(--dim);font-size:0.85rem}
#ct{flex:1;padding:1.5rem;overflow-y:auto}
.bk{background:var(--bg2);border:1px solid var(--border);border-radius:12px;margin-bottom:1rem;backdrop-filter:blur(10px);position:relative;overflow:hidden}
.bk::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--primary),transparent)}
.bh{display:flex;align-items:center;justify-content:space-between;padding:0.7rem 1rem;border-bottom:1px solid var(--border);cursor:pointer;background:rgba(0,240,255,0.02)}
.bh:hover{background:rgba(0,240,255,0.05)}
.bh h3{font-size:0.95rem;font-weight:600;color:var(--text)}
.bh .chevron{transition:.2s}
.bh .chevron.rot{transform:rotate(90deg)}
.bd{padding:1rem}
.bd.collapsed{display:none}
.st{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:0.8rem;margin-bottom:1rem}
.sc{text-align:center;padding:1.2rem 0.5rem;background:var(--bg3);border-radius:12px;border:1px solid var(--border)}
.sn{font-family:'Orbitron',sans-serif;font-size:1.5rem;font-weight:700;color:var(--primary);text-shadow:0 0 10px rgba(0,240,255,0.3)}
.sl{font-size:0.78rem;color:var(--dim);margin-top:0.2rem}
table{width:100%;border-collapse:collapse}
th,td{text-align:left;padding:0.6rem 0.8rem;border-bottom:1px solid var(--border);font-size:0.85rem}
th{color:var(--primary);font-weight:600;font-size:0.78rem;background:rgba(0,240,255,0.03);font-family:'Orbitron',sans-serif;text-transform:uppercase}
tr:hover td{background:rgba(0,240,255,0.03)}
.fc{background:var(--bg3);border-radius:6px;padding:1rem;margin-bottom:1rem}
.fr{display:flex;gap:0.8rem;flex-wrap:wrap;margin-bottom:0.5rem}
.fg{flex:1;min-width:160px}
.fg label{display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem}
input,select,textarea{width:100%;padding:0.45rem 0.7rem;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:0.85rem;border-radius:4px;outline:none;font-family:inherit}
input:focus,select:focus{border-color:var(--primary)}
textarea{resize:vertical;min-height:70px}
.sw{display:flex;align-items:center;gap:0.5rem}
.sw .toggle{position:relative;width:40px;height:22px;background:var(--border);border-radius:11px;cursor:pointer;transition:.2s}
.sw .toggle.on{background:var(--primary)}
.sw .toggle::after{content:'';position:absolute;top:2px;left:2px;width:18px;height:18px;background:#fff;border-radius:50%;transition:.2s}
.sw .toggle.on::after{left:20px}
.btn{display:inline-flex;align-items:center;gap:0.3rem;padding:0.4rem 0.8rem;font-size:0.85rem;border-radius:4px;border:1px solid transparent;cursor:pointer;font-family:inherit;transition:.15s;white-space:nowrap}
.btn-p{background:var(--primary);color:#fff;border-color:var(--primary)}
.btn-p:hover{opacity:.85}
.btn-a{background:var(--bg3);border-color:var(--border);color:var(--text)}
.btn-a:hover{background:var(--primary);border-color:var(--primary);color:#fff}
.btn-dr{background:var(--bg3);border-color:var(--border);color:var(--danger)}
.btn-dr:hover{background:var(--danger);border-color:var(--danger);color:#fff}
.btn-w{background:var(--bg3);border-color:var(--border);color:var(--warning)}
.btn-w:hover{background:var(--warning);border-color:var(--warning);color:#fff}
.btn-sm{padding:0.25rem 0.5rem;font-size:0.78rem}
.btn-full{width:100%;padding:0.6rem;margin-top:0.5rem}
.switch{position:relative;display:inline-block;width:44px;height:24px}
.switch input{opacity:0;width:0;height:0}
.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background-color:var(--border);transition:.4s;border-radius:24px}
.slider:before{position:absolute;content:"";height:18px;width:18px;left:3px;bottom:3px;background-color:white;transition:.4s;border-radius:50%}
input:checked + .slider{background-color:var(--primary)}
input:checked + .slider:before{transform:translateX(20px)}
.bg{display:inline-block;padding:0.1rem 0.4rem;font-size:0.72rem;border-radius:3px}
.bg.paid{background:rgba(66,165,245,.2);color:var(--primary)}
.bg.done{background:rgba(102,187,106,.2);color:var(--success)}
.bg.wait{background:rgba(255,167,38,.2);color:var(--warning)}
.bg.bad{background:rgba(239,83,80,.2);color:var(--danger)}
.bg.yes{background:rgba(102,187,106,.2);color:var(--success)}
.bg.no{background:rgba(136,142,160,.2);color:var(--dim)}
.bg.on{background:rgba(66,165,245,.2);color:var(--primary)}
.bg.off{background:rgba(136,142,160,.2);color:var(--dim)}
.ac{display:flex;gap:0.3rem;flex-wrap:wrap}
.tw{overflow-x:auto}
.tc{position:fixed;top:60px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:6px}
.tt{padding:10px 20px;border-radius:6px;font-size:.85rem;border:1px solid;animation:ti .3s ease}
.tt.ok{background:rgba(0,255,136,.1);border-color:var(--success);color:var(--success)}
.tt.er{background:rgba(255,0,0,.1);border-color:var(--danger);color:var(--danger)}
@keyframes ti{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.lo{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:1rem;background:var(--bg);width:100%;position:fixed;top:0;left:0}
.sp{width:30px;height:30px;border:3px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:s .6s linear infinite}
@keyframes s{to{transform:rotate(360deg)}}
.fw{width:100%}
.mt05{margin-top:.5rem}
.mb1{margin-bottom:1rem}
.fl{display:flex;gap:0.5rem;margin-bottom:1rem}
.fl button{padding:0.4rem 0.8rem;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:4px;cursor:pointer}
.fl button.active{background:var(--primary);border-color:var(--primary)}
.hr{border:none;border-top:1px solid var(--border);margin:1rem 0}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:1000;animation:fadeIn .2s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:12px;width:95%;max-width:800px;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;animation:slideUp .3s}
@keyframes slideUp{from{transform:translateY(50px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.5rem;border-bottom:1px solid var(--border);background:var(--bg3)}
.modal-header h2{font-size:1.1rem;font-weight:600;color:var(--primary)}
.modal-close{background:none;border:none;color:var(--dim);font-size:1.5rem;cursor:pointer;padding:0.25rem;line-height:1}
.modal-close:hover{color:var(--text)}
.modal-body{padding:1.5rem;overflow-y:auto;flex:1}
.modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:0.5rem;justify-content:flex-end}
.form-section{background:var(--bg3);border-radius:8px;padding:1rem;margin-bottom:1rem}
.form-section h3{font-size:0.9rem;font-weight:600;margin-bottom:0.8rem;color:var(--primary);display:flex;align-items:center;gap:0.5rem}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem}
.preview-box{border:2px dashed var(--border);border-radius:8px;padding:2rem;text-align:center;color:var(--dim);cursor:pointer;transition:.2s;min-height:150px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.preview-box:hover{border-color:var(--primary);background:rgba(66,165,245,0.05)}
.preview-box.has-image{border-style:solid;padding:1rem}
.preview-box img{max-width:100%;max-height:200px;border-radius:6px}
.inventory-card{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:0.8rem;margin-bottom:0.5rem}
.inventory-card:last-child{margin-bottom:0}
.stock-badge{display:inline-block;padding:0.2rem 0.6rem;font-size:0.75rem;border-radius:4px}
.stock-badge.available{background:rgba(102,187,106,.2);color:var(--success)}
.stock-badge.sold{background:rgba(239,83,80,.2);color:var(--danger)}
.stock-badge.low{background:rgba(255,167,38,.2);color:var(--warning)}
.stock-badge.empty{background:rgba(239,83,80,.2);color:var(--danger)}
.stock-display{display:flex;align-items:center;gap:0.25rem;font-family:'Orbitron',sans-serif}
.stock-number{font-size:1rem;font-weight:700;min-width:40px;text-align:center}
.stock-number.high{color:var(--success)}
.stock-number.medium{color:var(--warning)}
.stock-number.low{color:#ff9800}
.stock-number.empty{color:var(--danger)}
.stock-separator{color:var(--dim);font-size:0.85rem}
.stock-total{color:var(--dim);font-size:0.85rem}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
.stock-updated{animation:pulse 0.5s ease}
.restock-section{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:1.5rem;margin-top:1rem}
.restock-info{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--border)}
.restock-product{display:flex;align-items:center;gap:1rem}
.restock-product-info h4{font-size:1rem;margin-bottom:0.25rem}
.restock-stats{display:flex;gap:1.5rem}
.restock-stat{text-align:center}
.restock-stat .num{font-size:1.5rem;font-weight:700;color:var(--primary)}
.restock-stat .label{font-size:0.75rem;color:var(--dim)}
.restock-form{display:grid;gap:1rem}
.restock-form input{font-size:1.2rem;padding:0.8rem;text-align:center}
.restock-buttons{display:flex;gap:0.5rem;margin-top:1rem}
.quick-buttons{display:flex;gap:0.5rem;flex-wrap:wrap}
.quick-btn{padding:0.4rem 0.8rem;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:4px;cursor:pointer;font-size:0.85rem}
.quick-btn:hover{background:var(--primary);border-color:var(--primary)}
.file-upload-area{border:2px dashed var(--border);border-radius:8px;padding:1.5rem;text-align:center;color:var(--dim);cursor:pointer;transition:.2s;min-height:120px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.file-upload-area:hover{border-color:var(--primary);background:rgba(66,165,245,0.05)}
.file-list{display:flex;flex-direction:column;gap:0.5rem;margin-top:1rem}
.file-item{display:flex;align-items:center;justify-content:space-between;padding:0.75rem;background:var(--bg);border:1px solid var(--border);border-radius:6px}
.file-info{display:flex;align-items:center;gap:0.75rem}
.file-icon{width:36px;height:36px;background:var(--bg3);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.file-name{font-size:0.85rem}
.file-size{font-size:0.75rem;color:var(--dim)}
.file-action{display:flex;gap:0.5rem}
.compress-btn{background:var(--success);border:none;color:#fff;padding:0.5rem 1rem;border-radius:6px;cursor:pointer;font-size:0.85rem}
.recommend-section{margin-bottom:1.5rem}
.recommend-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.recommend-products{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.product-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;overflow:hidden;cursor:pointer;transition:.2s}
.product-card:hover{border-color:var(--primary);transform:translateY(-2px)}
.product-card.selected{border-color:var(--primary);box-shadow:0 0 0 2px rgba(66,165,245,0.2)}
.product-card-img{width:100%;height:140px;object-fit:cover;background:var(--bg3);display:flex;align-items:center;justify-content:center}
.product-card-info{padding:0.75rem}
.product-card-name{font-size:0.85rem;font-weight:500;margin-bottom:0.25rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.product-card-price{font-size:0.95rem;font-weight:700;color:var(--primary)}
.add-product-btn{border:2px dashed var(--border);height:100%;min-height:200px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--dim);border-radius:8px;cursor:pointer;transition:.2s}
.add-product-btn:hover{border-color:var(--primary);color:var(--primary);background:rgba(66,165,245,0.05)}
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.chart-box{background:var(--bg3);border-radius:10px;padding:1rem}
.chart-box h4{font-size:0.85rem;margin-bottom:1rem;color:var(--text);display:flex;align-items:center;gap:0.5rem}
.chart-wrap{min-height:220px;display:flex;align-items:flex-end}
.chart-bars{display:flex;align-items:flex-end;gap:3px;width:100%;height:200px;padding-bottom:20px;position:relative;border-bottom:1px solid var(--border)}
.bar-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;min-width:0}
.bar-fill{width:100%;max-width:30px;background:linear-gradient(to top,var(--neon-cyan),var(--neon-purple));border-radius:3px 3px 0 0;transition:height 0.5s;cursor:pointer;min-height:2px}
.bar-fill:hover{opacity:0.8}
.bar-label{font-size:0.6rem;color:var(--dim);margin-top:4px;white-space:nowrap}

</style>
</head>
<body>
  <canvas id="particle-canvas"></canvas>
<div id="app">
<div v-if="!ready" class="lo">
  <div class="sp"></div>
  <p style="color:var(--dim)">{{ msg }}</p>
</div>
<template v-if="ready">
<aside id="sidebar">
  <div class="shdr"><span>管理后台</span><a href="/" target="_blank" style="color:var(--dim);font-size:.8rem;margin-left:auto"><i class="fas fa-external-link-alt"></i></a></div>
  <div class="ub">
    <div class="av">{{ (un||'A').charAt(0).toUpperCase() }}</div>
    <div class="un">{{ un||'管理员' }}</div>
    <div class="ua"><a href="/" target="_blank"><i class="fas fa-home"></i> 前台</a><a href="/admin-login" style="color:var(--danger)"><i class="fas fa-sign-out-alt"></i> 退出</a></div>
  </div>
  <div class="nav">
    <template v-for="m in me" :key="m.k">
      <div v-if="m.divider" class="divider">{{ m.l }}</div>
      <a v-else :class="{on:tb===m.k}" href="#" @click.prevent="tb=m.k"><i :class="m.i"></i>{{ m.l }}</a>
    </template>
  </div>
  <div class="sf">v1.0.0</div>
</aside>
<main id="main">
  <div id="hdr"><i class="fas fa-bars" style="cursor:pointer;color:var(--dim)"></i><span class="tl">{{ al }}</span></div>
  <div id="ct">
    <div v-if="tb==='db'" class="bk">
      <div class="bh"><h3>数据概览</h3></div>
      <div class="bd">
        <div class="st">
          <div class="sc"><div class="sn">{{ da.order_num||da.today_orders||0 }}</div><div class="sl">今日订单</div></div>
          <div class="sc"><div class="sn">¥{{ ((da.turnover||da.today_income||0)*1).toFixed(2) }}</div><div class="sl">今日收入</div></div>
          <div class="sc"><div class="sn">{{ da.all_order_num||da.all_orders||0 }}</div><div class="sl">总订单</div></div>
          <div class="sc"><div class="sn">¥{{ ((da.all_turnover||da.all_income||0)*1).toFixed(2) }}</div><div class="sl">总收入</div></div>
          <div class="sc"><div class="sn">{{ da.total_users||0 }}</div><div class="sl">用户数</div></div>
        </div>
      </div>
      <div class="bd">
        <div class="chart-row">
          <div class="chart-box">
            <h4><i class="fas fa-calendar-day"></i> 本月每日收入</h4>
            <div class="chart-wrap">
              <div class="chart-bars" v-if="charts.daily.length">
                <div class="bar-item" v-for="d in charts.daily" :key="d.day">
                  <div class="bar-fill" :style="{height: (d.income / maxDaily * 180) + 'px'}" :title="'¥'+d.income"></div>
                  <span class="bar-label">{{ d.day }}日</span>
                </div>
              </div>
              <div v-else style="text-align:center;color:var(--dim);padding:2rem">暂无数据</div>
            </div>
          </div>
          <div class="chart-box">
            <h4><i class="fas fa-chart-line"></i> 近12月收入</h4>
            <div class="chart-wrap">
              <div class="chart-bars" v-if="charts.monthly.length">
                <div class="bar-item" v-for="m in charts.monthly" :key="m.month">
                  <div class="bar-fill" :style="{height: (m.income / maxMonthly * 180) + 'px'}" :title="'¥'+m.income"></div>
                  <span class="bar-label">{{ m.month.slice(5) }}月</span>
                </div>
              </div>
              <div v-else style="text-align:center;color:var(--dim);padding:2rem">暂无数据</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div v-if="tb==='pd'" class="bk">
      <div class="bh"><h3>商品管理</h3><div style="display:flex;gap:0.5rem;align-items:center">
        <span style="font-size:0.75rem;color:var(--dim)">
          <i class="fas fa-sync fa-spin" v-if="refreshingStock"></i>
          <i class="fas fa-sync" v-else @click="refreshAllStocks" style="cursor:pointer" title="点击刷新库存"></i>
          实时库存监控中
        </span>
        <button class="btn btn-p btn-sm" @click="openProductModal()">+ 添加商品</button>
      </div></div>
      <div class="bd tw">
        <table><thead><tr><th>ID</th><th>名称</th><th>价格</th><th>类型</th><th>剩余库存</th><th>状态</th><th>操作</th></tr></thead>
        <tbody><tr v-for="p in ps" :key="p.id">
          <td>{{ p.id }}</td>
          <td><strong>{{ p.name }}</strong></td>
          <td><span style="color:var(--primary);font-weight:600">¥{{ p.price }}</span></td>
          <td><span class="bg" :class="p.type">{{ p.type==='blindbox'?'🎁盲盒':'📦普通' }}</span></td>
          <td>
            <div class="stock-display">
              <span class="stock-number" :class="getStockClass(p)">{{ p.available_stock||0 }}</span>
              <span class="stock-separator">/</span>
              <span class="stock-total">{{ p.total_stock||0 }}</span>
            </div>
          </td>
          <td><span class="stock-badge" :class="getStockStatus(p)">{{ getStockText(p) }}</span></td>
          <td class="ac">
            <button class="btn btn-sm btn-a" @click="openProductModal(p)">编辑</button>
            <button class="btn btn-sm btn-p" @click="openRestockModal(p)"><i class="fas fa-plus"></i> 补货</button>
            <button class="btn btn-sm btn-a" @click="sk(p)">卡密</button>
            <button class="btn btn-sm btn-w" v-if="p.type==='blindbox'" @click="sp(p)">奖池</button>
          </td>
        </tr></tbody></table>
      </div>
    </div>
    <div v-if="tb==='rc'" class="bk">
      <div class="bh"><h3>推荐商品编辑</h3><button class="btn btn-p btn-sm" @click="addRecommendCategory">+ 添加推荐分类</button></div>
      <div class="bd">
        <div v-for="(rc,idx) in recommends" :key="idx" class="recommend-section">
          <div class="recommend-header">
            <div style="display:flex;gap:1rem;align-items:center">
              <input v-model="rc.category_name" placeholder="分类名称" style="width:200px;padding:0.5rem;border-radius:4px;border:1px solid var(--border);background:var(--bg3);color:var(--text)" />
              <select v-model="rc.category_id" style="width:150px;padding:0.5rem;border-radius:4px;border:1px solid var(--border);background:var(--bg3);color:var(--text)">
                <option :value="0">无分类</option>
                <option v-for="c in ct" :key="c.id" :value="c.id">{{ c.name }}</option>
              </select>
              <input v-model.number="rc.sort_order" type="number" placeholder="排序权重" style="width:100px;padding:0.5rem;border-radius:4px;border:1px solid var(--border);background:var(--bg3);color:var(--text)" />
            </div>
            <div style="display:flex;gap:0.5rem">
              <button class="btn btn-a btn-sm" @click="saveRecommend(rc)">保存</button>
              <button class="btn btn-sm" style="background:var(--danger);border:none" @click="deleteRecommend(rc.id)">删除</button>
            </div>
          </div>
          <div class="recommend-products">
            <div class="product-card" v-for="p in rc.products" :class="{selected:rc.product_ids?.includes(p.id)}" @click="toggleProductInRecommend(rc, p.id)">
              <div class="product-card-img">
                <img v-if="p.image_url" :src="p.image_url" style="width:100%;height:100%;object-fit:cover" />
                <i v-else class="fas fa-image" style="font-size:2rem;color:var(--dim)" />
              </div>
              <div class="product-card-info">
                <div class="product-card-name">{{ p.name }}</div>
                <div class="product-card-price">¥{{ p.price.toFixed(2) }}</div>
              </div>
              <div v-if="rc.product_ids?.includes(p.id)" style="position:absolute;top:0.5rem;right:0.5rem;background:var(--primary);color:#fff;border-radius:50%;width:24px;height:24px;display:flex;align-items:center;justify-content:center">
                <i class="fas fa-check"></i>
              </div>
            </div>
            <div class="add-product-btn" @click="openAddProductModal(rc)">
              <i class="fas fa-plus" style="font-size:2rem;margin-bottom:0.5rem"></i>
              <p>添加商品</p>
            </div>
          </div>
        </div>
        <div v-if="recommends.length===0" style="text-align:center;color:var(--dim);padding:3rem 0">
          <i class="fas fa-star" style="font-size:3rem;margin-bottom:1rem"></i>
          <p>暂无推荐分类，请添加推荐分类开始</p>
        </div>
      </div>
    </div>
    <div v-if="tb==='ke'" class="bk">
      <div class="bh"><h3>卡密管理</h3></div>
      <div class="bd">
        <div class="fc" v-if="kp">
          <p style="margin-bottom:0.5rem">商品: {{ kp }} (ID: {{ kp }})</p>
          <textarea v-model="kt" placeholder="每行一个卡密" style="min-height:100px"></textarea>
          <button class="btn btn-p btn-sm mt05" @click="imK">批量导入</button>
        </div>
        <div class="tw mt05" v-if="ks.length"><table><thead><tr><th>卡密</th><th>状态</th></tr></thead><tbody><tr v-for="k in ks" :key="k.id"><td style="font-family:monospace;color:var(--success)">{{ k.key }}</td><td><span class="bg" :class="k.status">{{ k.status }}</span></td></tr></tbody></table></div>
      </div>
    </div>
    <div v-if="tb==='or'" class="bk">
      <div class="bh"><h3>订单管理</h3></div>
      <div class="bd tw">
        <table><thead><tr><th>订单号</th><th>商品</th><th>金额</th><th>状态</th><th>时间</th></tr></thead>
        <tbody><tr v-for="o in or" :key="o.id"><td style="font-family:monospace;font-size:.8rem">#{{ o.order_no }}</td><td>{{ o.product?.name||'-' }}</td><td>¥{{ o.final_price.toFixed(2) }}</td><td><span class="bg" :class="o.status">{{ stTxt(o.status) }}</span></td><td style="color:var(--dim);font-size:.8rem">{{ fm(o.created_at) }}</td></tr></tbody></table>
      </div>
    </div>
    <div v-if="tb==='us'" class="bk">
      <div class="bh"><h3>用户管理</h3></div>
      <div class="bd tw">
        <table><thead><tr><th>ID</th><th>用户名</th><th>等级</th><th>积分</th><th>邮箱</th><th>管理员</th><th>注册时间</th></tr></thead>
        <tbody><tr v-for="u in us" :key="u.id"><td>{{ u.id }}</td><td>{{ u.username }}</td><td>Lv{{ u.level }}</td><td>{{ u.points }}</td><td style="color:var(--dim)">{{ u.email||'-' }}</td><td><span class="bg" :class="u.is_admin?'yes':'no'">{{ u.is_admin?'是':'否' }}</span></td><td style="color:var(--dim);font-size:.8rem">{{ fm(u.created_at) }}</td></tr></tbody></table>
      </div>
    </div>
    <div v-if="tb==='cp'" class="bk">
      <div class="bh"><h3><i class="fas fa-gift"></i> 优惠券管理</h3><button class="btn btn-p btn-sm" @click="showAddCoupon=!showAddCoupon">+ 添加优惠券</button></div>
      <div v-if="showAddCoupon" class="fc">
        <div class="form-section">
          <h3><i class="fas fa-plus"></i> 添加优惠券</h3>
          <div class="fr">
            <div class="fg"><label>优惠券名称/备注</label><input v-model="newCoupon.name" placeholder="如: 新用户专享" /></div>
            <div class="fg"><label>类型</label><select v-model="newCoupon.type"><option value="percentage">折扣%</option><option value="fixed">固定金额</option></select></div>
            <div class="fg"><label>优惠值</label><input v-model.number="newCoupon.value" type="number" placeholder="如: 10" /></div>
          </div>
          <div class="fr">
            <div class="fg"><label>最低消费(元)</label><input v-model.number="newCoupon.min_amount" type="number" placeholder="0表示无门槛" /></div>
            <div class="fg"><label>发放数量(0不限)</label><input v-model.number="newCoupon.total_count" type="number" placeholder="0表示不限量" /></div>
            <div class="fg"><label>过期时间</label><input v-model="newCoupon.expires_at" type="datetime-local" /></div>
          </div>
        </div>
        <div style="display:flex;gap:0.5rem">
          <button class="btn btn-p" @click="addCoupon"><i class="fas fa-plus"></i> 添加</button>
          <button class="btn btn-a" @click="showAddCoupon=false">取消</button>
        </div>
      </div>
      <div class="bd tw">
        <table><thead><tr><th>ID</th><th>名称</th><th>类型</th><th>价值</th><th>最低消费</th><th>已发放/总量</th><th>过期时间</th><th>操作</th></tr></thead>
        <tbody><tr v-for="c in coupons" :key="c.id">
          <td>{{ c.id }}</td>
          <td><strong>{{ c.name }}</strong></td>
          <td><span class="bg on">{{ c.type === 'percentage' ? '折扣' : '金额' }}</span></td>
          <td style="color:var(--primary);font-weight:600">{{ c.type === 'percentage' ? c.value+'%' : '¥'+c.value }}</td>
          <td>{{ c.min_amount > 0 ? '¥'+c.min_amount : '无门槛' }}</td>
          <td><span :style="{color: c.issued_count >= c.total_count && c.total_count > 0 ? 'var(--danger)' : 'var(--success)'}">{{ c.issued_count||0 }}</span> / {{ c.total_count||'∞' }}</td>
          <td style="color:var(--dim);font-size:.8rem">{{ c.expires_at ? fm(c.expires_at) : '永不过期' }}</td>
          <td>
            <div class="ac">
              <button class="btn btn-sm btn-a" @click="giveCoupon(c)" title="发放给用户"><i class="fas fa-user-plus"></i> 发放</button>
              <button class="btn btn-sm btn-dr" @click="delCoupon(c.id)">删除</button>
            </div>
          </td>
        </tr></tbody></table>
        <div v-if="!coupons || coupons.length===0" style="text-align:center;color:var(--dim);padding:2rem">
          <i class="fas fa-gift" style="font-size:3rem;margin-bottom:1rem"></i>
          <p>暂无优惠券</p>
        </div>
      </div>
    </div>
    <div v-if="tb==='cr'" class="bk">
      <div class="bh"><h3><i class="fas fa-magic"></i> 优惠券规则管理</h3><button class="btn btn-p btn-sm" @click="showAddRule=!showAddRule">+ 添加规则</button></div>
      <div v-if="showAddRule" class="fc">
        <div class="form-section">
          <h3><i class="fas fa-plus"></i> 添加赠送规则</h3>
          <div class="fr">
            <div class="fg"><label>规则名称</label><input v-model="newRule.name" placeholder="如: 注册送券" /></div>
            <div class="fg"><label>触发类型</label>
              <select v-model="newRule.type">
                <option value="register">用户注册</option>
                <option value="purchase">购买商品</option>
                <option value="amount">订单满额</option>
              </select>
            </div>
            <div class="fg"><label>关联优惠券</label>
              <select v-model="newRule.coupon_id">
                <option :value="0">请选择</option>
                <option v-for="c in coupons" :key="c.id" :value="c.id">{{ c.name }} ({{ c.type === 'percentage' ? c.value+'%' : '¥'+c.value }})</option>
              </select>
            </div>
          </div>
          <div class="fr">
            <div class="fg"><label>赠送数量</label><input v-model.number="newRule.give_count" type="number" min="1" placeholder="1" /></div>
            <div class="fg" v-if="newRule.type==='purchase'"><label>指定商品ID</label><input v-model.number="newRule.product_id" type="number" placeholder="留空不限制" /></div>
            <div class="fg" v-if="newRule.type==='purchase'"><label>指定分类ID</label><input v-model.number="newRule.category_id" type="number" placeholder="留空不限制" /></div>
            <div class="fg" v-if="newRule.type==='amount'"><label>最低订单金额</label><input v-model.number="newRule.min_order_amount" type="number" placeholder="0" /></div>
          </div>
        </div>
        <div style="display:flex;gap:0.5rem">
          <button class="btn btn-p" @click="createRule"><i class="fas fa-plus"></i> 创建</button>
          <button class="btn btn-a" @click="showAddRule=false">取消</button>
        </div>
      </div>
      <div class="bd tw">
        <table><thead><tr><th>ID</th><th>规则名称</th><th>触发类型</th><th>赠送优惠券</th><th>赠送数量</th><th>启用</th><th>操作</th></tr></thead>
        <tbody><tr v-for="r in couponRules" :key="r.id">
          <td>{{ r.id }}</td>
          <td><strong>{{ r.name }}</strong></td>
          <td><span class="bg on">{{ r.type==='register'?'用户注册':r.type==='purchase'?'购买商品':'订单满额' }}</span></td>
          <td>{{ r.coupon_name }}</td>
          <td>{{ r.give_count }}</td>
          <td>
            <label class="switch">
              <input type="checkbox" v-model="r.enabled" @change="updateRule(r)" />
              <span class="slider"></span>
            </label>
          </td>
          <td>
            <div class="ac">
              <button class="btn btn-sm btn-dr" @click="deleteRule(r.id)">删除</button>
            </div>
          </td>
        </tr></tbody></table>
        <div v-if="!couponRules || couponRules.length===0" style="text-align:center;color:var(--dim);padding:2rem">
          <i class="fas fa-magic" style="font-size:3rem;margin-bottom:1rem"></i>
          <p>暂无优惠券赠送规则</p>
        </div>
      </div>
    </div>
    <div v-if="tb==='co'" class="bk">
      <div class="bh"><h3><i class="fas fa-ticket-alt"></i> 优惠码/兑换码管理</h3></div>
      <div class="bd" style="padding-bottom:0">
        <div class="fl">
          <button :class="{active:coTab==='promo'}" @click="coTab='promo'">优惠码（购物优惠）</button>
          <button :class="{active:coTab==='redeem'}" @click="coTab='redeem'">兑换码（获取优惠券）</button>
        </div>
      </div>
      
      <!-- 优惠码部分 -->
      <div v-if="coTab==='promo'" class="bd">
        <div class="form-section" style="margin-bottom:1rem">
          <h3><i class="fas fa-plus"></i> 添加优惠码</h3>
          <div class="fr">
            <div class="fg" style="flex:2"><label>优惠码</label>
              <div style="display:flex;gap:0.5rem">
                <input v-model="newPromo.code" placeholder="留空自动生成" style="flex:1" />
                <button class="btn btn-a btn-sm" @click="newPromo.code=generatePromoCode()"><i class="fas fa-magic"></i> 生成</button>
              </div>
            </div>
            <div class="fg"><label>优惠类型</label>
              <select v-model="newPromo.type">
                <option value="percentage">折扣%</option>
                <option value="fixed">固定金额</option>
              </select>
            </div>
            <div class="fg"><label>优惠值</label><input v-model.number="newPromo.value" type="number" placeholder="如: 10" /></div>
          </div>
          <div class="fr">
            <div class="fg"><label>最低消费(元)</label><input v-model.number="newPromo.min_amount" type="number" placeholder="0表示无门槛" /></div>
            <div class="fg"><label>可用次数(0不限)</label><input v-model.number="newPromo.max_uses" type="number" placeholder="0" /></div>
            <div class="fg"><label>过期时间</label><input v-model="newPromo.expires_at" type="datetime-local" /></div>
          </div>
          <div class="fr" style="margin-top:0.5rem">
            <div class="fg" style="flex:100%"><label>备注</label><input v-model="newPromo.remark" placeholder="如: 618活动" /></div>
          </div>
          <div style="margin-top:0.5rem">
            <button class="btn btn-p" @click="createPromoCode"><i class="fas fa-plus"></i> 创建</button>
          </div>
        </div>
        
        <table><thead><tr><th>优惠码</th><th>类型</th><th>优惠值</th><th>最低消费</th><th>已用/上限</th><th>过期时间</th><th>备注</th><th>操作</th></tr></thead>
        <tbody><tr v-for="p in promoCodes.filter(x=>x.type)":key="p.id">
          <td style="font-family:monospace;color:var(--primary);font-weight:600">{{ p.code }}</td>
          <td><span class="bg on">{{ p.type === 'percentage' ? '折扣' : '金额' }}</span></td>
          <td>{{ p.type === 'percentage' ? p.value+'%' : '¥'+p.value }}</td>
          <td>{{ p.min_amount? '¥'+p.min_amount : '无' }}</td>
          <td>{{ p.used_count||0 }}/{{ p.max_uses||'∞' }}</td>
          <td style="color:var(--dim);font-size:.8rem">{{ p.expires_at ? fm(p.expires_at) : '永不过期' }}</td>
          <td style="color:var(--dim)">{{ p.remark || '-' }}</td>
          <td><button class="btn btn-sm btn-a" @click="copyPromoCode(p.code)"><i class="fas fa-copy"></i> 复制</button><button class="btn btn-sm btn-dr" @click="dlCo(p.id)">删除</button></td>
        </tr></tbody></table>
        <div v-if="!promoCodes.filter(x=>x.type).length" style="text-align:center;color:var(--dim);padding:2rem">
          <p>暂无优惠码</p>
        </div>
      </div>
      
      <!-- 兑换码部分 -->
      <div v-if="coTab==='redeem'" class="bd">
        <div class="form-section" style="margin-bottom:1rem">
          <h3><i class="fas fa-plus"></i> 添加兑换码</h3>
          <div class="fr">
            <div class="fg" style="flex:2"><label>兑换码</label>
              <div style="display:flex;gap:0.5rem">
                <input v-model="newRedeem.code" placeholder="留空自动生成" style="flex:1" />
                <button class="btn btn-a btn-sm" @click="newRedeem.code=generatePromoCode()"><i class="fas fa-magic"></i> 生成</button>
              </div>
            </div>
            <div class="fg"><label>关联优惠券</label>
              <select v-model="newRedeem.coupon_id">
                <option :value="0">请选择</option>
                <option v-for="c in coupons" :key="c.id" :value="c.id">{{ c.name }} ({{ c.type === 'percentage' ? c.value+'%' : '¥'+c.value }})</option>
              </select>
            </div>
            <div class="fg"><label>赠送数量</label><input v-model.number="newRedeem.give_count" type="number" min="1" placeholder="1" /></div>
          </div>
          <div class="fr">
            <div class="fg"><label>可用次数(0不限)</label><input v-model.number="newRedeem.max_uses" type="number" placeholder="0" /></div>
            <div class="fg"><label>过期时间</label><input v-model="newRedeem.expires_at" type="datetime-local" /></div>
            <div class="fg" style="flex:100%"><label>备注</label><input v-model="newRedeem.remark" placeholder="如: 新用户专享" /></div>
          </div>
          <div style="margin-top:0.5rem">
            <button class="btn btn-p" @click="createRedeemCode"><i class="fas fa-plus"></i> 创建</button>
          </div>
        </div>
        
        <table><thead><tr><th>兑换码</th><th>关联优惠券</th><th>赠送数量</th><th>已用/上限</th><th>过期时间</th><th>备注</th><th>操作</th></tr></thead>
        <tbody><tr v-for="p in promoCodes.filter(x=>x.coupon_id)":key="p.id">
          <td style="font-family:monospace;color:var(--success);font-weight:600">{{ p.code }}</td>
          <td><span class="bg yes">{{ getCouponName(p.coupon_id) }}</span></td>
          <td>{{ p.give_count ||1}}</td>
          <td>{{ p.used_count||0 }}/{{ p.max_uses||'∞' }}</td>
          <td style="color:var(--dim);font-size:.8rem">{{ p.expires_at ? fm(p.expires_at) : '永不过期' }}</td>
          <td style="color:var(--dim)">{{ p.remark || '-' }}</td>
          <td><button class="btn btn-sm btn-a" @click="copyPromoCode(p.code)"><i class="fas fa-copy"></i> 复制</button><button class="btn btn-sm btn-dr" @click="dlCo(p.id)">删除</button></td>
        </tr></tbody></table>
        <div v-if="!promoCodes.filter(x=>x.coupon_id).length" style="text-align:center;color:var(--dim);padding:2rem">
          <p>暂无兑换码</p>
        </div>
      </div>
    </div>
    <div v-if="tb==='inv'" class="bk">
      <div class="bh"><h3><i class="fas fa-user-plus"></i> 邀请码管理</h3></div>
      <div class="bd">
        <div class="form-section" style="margin-bottom:1rem">
          <h3><i class="fas fa-cog"></i> 邀请奖励设置</h3>
          <div class="fr">
            <div class="fg"><label>被邀请人获得积分</label><input v-model.number="invSettings.reward_new_user" type="number" placeholder="注册后获得" /></div>
            <div class="fg"><label>邀请人获得积分</label><input v-model.number="invSettings.reward_inviter" type="number" placeholder="邀请后获得" /></div>
          </div>
          <div class="fr" v-if="coupons.length">
            <div class="fg"><label>被邀请人获得优惠券</label>
              <select v-model="invSettings.reward_coupon">
                <option :value="0">不赠送</option>
                <option v-for="c in coupons" :key="c.id" :value="c.id">{{ c.name }} ({{ c.type === 'percentage' ? c.value+'%' : '¥'+c.value }})</option>
              </select>
            </div>
            <div class="fg"><label>赠送数量</label><input v-model.number="invSettings.reward_coupon_count" type="number" min="1" placeholder="1" /></div>
          </div>
          <div style="margin-top:0.5rem">
            <button class="btn btn-p" @click="saveInvSettings"><i class="fas fa-save"></i> 保存设置</button>
          </div>
        </div>
        
        <div class="hr"></div>
        
        <div class="form-section" style="margin-bottom:1rem">
          <h3><i class="fas fa-list"></i> 邀请记录</h3>
          <table><thead><tr><th>ID</th><th>被邀请人</th><th>邀请人</th><th>邀请码</th><th>时间</th><th>奖励已发放</th></tr></thead>
          <tbody><tr v-for="ir in inviteRecords" :key="ir.id">
            <td>{{ ir.id }}</td>
            <td>{{ ir.new_user?.username || '-' }}</td>
            <td>{{ ir.inviter?.username || '-' }}</td>
            <td style="font-family:monospace">{{ ir.code }}</td>
            <td style="color:var(--dim);font-size:.8rem">{{ fm(ir.created_at) }}</td>
            <td><span class="bg" :class="ir.reward_issued?'yes':'no'">{{ ir.reward_issued?'是':'否' }}</span></td>
          </tr></tbody></table>
          <div v-if="!inviteRecords.length" style="text-align:center;color:var(--dim);padding:2rem">
            <p>暂无邀请记录</p>
          </div>
        </div>
      </div>
    </div>
    <div v-if="tb==='ct'" class="bk">
      <div class="bh"><h3>分类管理</h3><button class="btn btn-p btn-sm" @click="scf=!scf">+ 新建</button></div>
      <div v-if="scf" class="fc">
        <div class="fr"><div class="fg"><label>名称</label><input v-model="cf.name" /></div><div class="fg"><label>排序</label><input v-model.number="cf.sort_order" type="number" /></div></div>
        <button class="btn btn-p btn-sm" @click="mkCt">创建</button>
      </div>
      <div class="bd tw">
        <table><thead><tr><th>ID</th><th>名称</th><th>排序</th><th>操作</th></tr></thead>
        <tbody><tr v-for="c in ct" :key="c.id"><td>{{ c.id }}</td><td>{{ c.name }}</td><td>{{ c.sort_order||0 }}</td><td><button class="btn btn-sm btn-dr" @click="dlCt(c.id)">删除</button></td></tr></tbody></table>
      </div>
    </div>
    <div v-if="tb==='st'" class="bk">
      <div class="bh" @click="toggleAccordion('st_basic')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_basic}"></i> 基本设置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_basic}">
        <div class="fr"><div class="fg"><label>店铺名称</label><input v-model="st.shop_name" /></div><div class="fg"><label>网站标题</label><input v-model="st.title" /></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>公告</label><textarea v-model="st.notice"></textarea></div></div>
        <div class="hr"></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>关键词(SEO)</label><input v-model="st.keywords" placeholder="用逗号分隔，例如: 游戏,点卡,充值" /></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>网站描述(SEO)</label><textarea v-model="st.description" placeholder="网站描述，用于搜索引擎"></textarea></div></div>
        <div class="hr"></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>Logo URL</label><input v-model="st.logo" placeholder="输入Logo图片URL地址" /></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>PC端背景图URL</label><input v-model="st.background_url" placeholder="输入背景图片URL地址" /></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>手机端背景图URL</label><input v-model="st.background_mobile_url" placeholder="不设置则使用PC版配置" /></div></div>
        <div class="hr"></div>
        <div class="fr"><label style="font-size:0.78rem;color:var(--dim);margin-bottom:0.5rem"><i class="fas fa-headset"></i> 客服联系方式</label></div>
        <div class="fr"><div class="fg"><label>客服QQ</label><input v-model="st.service_qq" placeholder="客服QQ号码" /></div><div class="fg"><label>客服微信</label><input v-model="st.service_wechat" placeholder="客服微信号" /></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>客服邮箱</label><input v-model="st.service_email" placeholder="客服邮箱" /></div></div>
        <div class="hr"></div>
        <div class="fr"><label style="font-size:0.78rem;color:var(--dim);margin-bottom:0.5rem"><i class="fas fa-qrcode"></i> 二维码图片</label></div>
        <div class="fr"><div class="fg"><label>二维码1标题</label><input v-model="st.qrcode1_title" placeholder="如: 微信" /></div><div class="fg" style="flex:100%"><label>二维码1图片URL</label><input v-model="st.qrcode1_url" placeholder="输入二维码图片URL" /></div></div>
        <div class="fr"><div class="fg"><label>二维码2标题</label><input v-model="st.qrcode2_title" placeholder="如: 微信公众号" /></div><div class="fg" style="flex:100%"><label>二维码2图片URL</label><input v-model="st.qrcode2_url" placeholder="输入二维码图片URL" /></div></div>
        <div class="hr"></div>
        <div class="fr"><div class="fg"><label>注册方式</label><select v-model="st.register_type"><option value="username">仅用户名</option><option value="email">用户名+邮箱</option></select></div><div class="fg"><label>找回密码</label><select v-model="st.forget_type"><option value="email">邮箱验证码</option></select></div></div>
        <div class="fr"><div class="fg"><label>会话有效期(秒)</label><input v-model.number="st.session_expire" type="number" /></div><div class="fg"><label>管理员会话(分钟)</label><input v-model.number="st.admin_session_expire" type="number" placeholder="默认30分钟" /></div></div>
        <div class="fr"><div class="fg"><label>注册用户名最小长度</label><input v-model.number="st.username_min_len" type="number" /></div></div>
        <div class="hr"></div>
        <div class="fr" style="flex-direction:column;align-items:flex-start">
          <label style="font-size:0.78rem;color:var(--dim);margin-bottom:0.5rem"><i class="fas fa-shield-alt"></i> 验证码设置</label>
          <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.allow_register}" @click="st.allow_register=!st.allow_register"></div><label>允许注册</label></div><div class="sw"><div class="toggle" :class="{on:st.login_captcha}" @click="st.login_captcha=!st.login_captcha"></div><label>登录验证码</label></div><div class="sw"><div class="toggle" :class="{on:st.register_captcha}" @click="st.register_captcha=!st.register_captcha"></div><label>注册验证码</label></div></div>
          <div class="fr" style="margin-top:0.5rem"><div class="sw"><div class="toggle" :class="{on:st.trade_captcha}" @click="st.trade_captcha=!st.trade_captcha"></div><label>下单验证码</label></div><div class="sw"><div class="toggle" :class="{on:st.register_verification}" @click="st.register_verification=!st.register_verification"></div><label>注册人机验证</label></div></div>
        </div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
      <div class="bh" @click="toggleAccordion('st_theme')"><h3><i class="fas fa-palette"></i> 主题设置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_theme}">
        <div class="theme-selector">
          <div class="theme-option" :class="{active:currentTheme==='cyberpunk'}" @click="changeTheme('cyberpunk')">
            <span class="theme-preview theme-cyberpunk"></span>赛博朋克
          </div>
          <div class="theme-option" :class="{active:currentTheme==='simple'}" @click="changeTheme('simple')">
            <span class="theme-preview theme-simple-preview"></span>简约风格
          </div>
          <div class="theme-option" :class="{active:currentTheme==='cute'}" @click="changeTheme('cute')">
            <span class="theme-preview theme-cute-preview"></span>少女风格
          </div>
          <div class="theme-option" :class="{active:currentTheme==='anime'}" @click="changeTheme('anime')">
            <span class="theme-preview theme-anime-preview"></span>二次元风格
          </div>
        </div>
        <p style="font-size:0.85rem;color:var(--dim);margin-top:0.5rem">
          <i class="fas fa-info-circle"></i> 
          赛博朋克：深蓝色背景，青色霓虹粒子效果<br>
          简约风格：浅色背景，Home Assistant风格，粒子相互吸引<br>
          少女风格：粉色系背景，飘浮爱心粒子<br>
          二次元风格：紫色系背景，二次元配色粒子
        </p>
      </div>
      <div class="bh" @click="toggleAccordion('st_email')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_email}"></i> 邮件配置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_email}">
        <div class="fr"><div class="fg"><label>SMTP服务器</label><input v-model="st.email_smtp" placeholder="smtp.example.com" /></div><div class="fg"><label>端口</label><input v-model.number="st.email_port" type="number" placeholder="465" /></div></div>
        <div class="fr"><div class="fg"><label>加密协议</label><select v-model="st.email_secure"><option value="ssl">SSL</option><option value="tls">TLS</option></select></div></div>
        <div class="fr"><div class="fg"><label>用户名</label><input v-model="st.email_username" placeholder="your@email.com" /></div><div class="fg"><label>授权码</label><input v-model="st.email_password" type="password" placeholder="邮箱授权码" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-a btn-sm" @click="testEmail">发送测试邮件</button><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
      <div class="bh" @click="toggleAccordion('st_sms')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_sms}"></i> 短信配置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_sms}">
        <div class="fr"><div class="fg"><label>短信平台</label><select v-model="st.sms_platform"><option value="aliyun">阿里云</option><option value="tencent">腾讯云</option><option value="dxbao">短信宝</option></select></div></div>
        
        <div v-if="st.sms_platform === 'aliyun'" class="sms-config">
          <div class="fr"><div class="fg"><label>AccessKeyId</label><input v-model="st.sms_access_key_id" /></div><div class="fg"><label>AccessKeySecret</label><input v-model="st.sms_access_key_secret" type="password" /></div></div>
          <div class="fr"><div class="fg"><label>签名名称</label><input v-model="st.sms_sign_name" /></div><div class="fg"><label>模板CODE</label><input v-model="st.sms_template_code" /></div></div>
        </div>
        
        <div v-if="st.sms_platform === 'tencent'" class="sms-config">
          <div class="fr"><div class="fg"><label>secretId</label><input v-model="st.sms_secret_id" /></div><div class="fg"><label>secretKey</label><input v-model="st.sms_secret_key" type="password" /></div></div>
          <div class="fr"><div class="fg"><label>sdkAppId</label><input v-model="st.sms_sdk_app_id" /></div><div class="fg"><label>签名名称</label><input v-model="st.sms_sign_name" /></div></div>
          <div class="fr"><div class="fg"><label>模板ID</label><input v-model="st.sms_template_id" /></div></div>
        </div>
        
        <div v-if="st.sms_platform === 'dxbao'" class="sms-config">
          <div class="fr"><div class="fg"><label>账号</label><input v-model="st.sms_dxbao_username" /></div><div class="fg"><label>密码</label><input v-model="st.sms_dxbao_password" type="password" /></div></div>
          <div class="fr"><div class="fg" style="flex:100%"><label>短信模板</label><input v-model="st.sms_dxbao_template" placeholder="模板，如：【XXX】您的验证码为{code}，在5分钟内有效。" /></div></div>
        </div>
        
        <div class="fr" style="margin-top:1rem"><button class="btn btn-a btn-sm" @click="testSms">发送测试短信</button><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
      <div class="bh" @click="toggleAccordion('st_pay')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_pay}"></i> 支付设置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_pay}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.pay_wx}" @click="st.pay_wx=!st.pay_wx"></div><label>微信支付</label></div><div class="sw"><div class="toggle" :class="{on:st.pay_alipay}" @click="st.pay_alipay=!st.pay_alipay"></div><label>支付宝</label></div><div class="sw"><div class="toggle" :class="{on:st.pay_mazf}" @click="st.pay_mazf=!st.pay_mazf"></div><label>码支付</label></div><div class="sw"><div class="toggle" :class="{on:st.pay_yishoumi}" @click="st.pay_yishoumi=!st.pay_yishoumi"></div><label>易收米</label></div><div class="sw"><div class="toggle" :class="{on:st.pay_usdt}" @click="st.pay_usdt=!st.pay_usdt"></div><label>USDT</label></div><div class="sw"><div class="toggle" :class="{on:st.pay_qq}" @click="st.pay_qq=!st.pay_qq"></div><label>QQ钱包</label></div></div>
        <div v-if="st.pay_mazf" class="form-section" style="margin-top:1rem">
          <h3><i class="fas fa-cog"></i> 码支付配置</h3>
          <div class="fr"><div class="fg"><label>商户ID</label><input v-model="st.mazf_mch_id" placeholder="码支付商户ID" /></div><div class="fg"><label>商户密钥</label><input v-model="st.mazf_key" type="password" placeholder="码支付密钥" /></div></div>
        </div>
        <div v-if="st.pay_yishoumi" class="form-section" style="margin-top:1rem">
          <h3><i class="fas fa-cog"></i> 易收米配置</h3>
          <div class="fr"><div class="fg"><label>AppId</label><input v-model="st.yishoumi_app_id" placeholder="易收米AppId" /></div><div class="fg"><label>AppKey</label><input v-model="st.yishoumi_app_key" type="password" placeholder="易收米AppKey" /></div></div>
          <div class="fr"><div class="fg" style="flex:100%"><label>NotifyUrl</label><input v-model="st.yishoumi_notify_url" placeholder="回调地址" /></div></div>
        </div>
        <div class="hr"></div>
        <div class="fr"><div class="fg"><label>最低充值</label><input v-model.number="st.recharge_min" type="number" /></div><div class="fg"><label>最高充值</label><input v-model.number="st.recharge_max" type="number" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.recharge_welfare}" @click="st.recharge_welfare=!st.recharge_welfare"></div><label>充值赠送</label></div><div class="fg"><label>赠送比例(%)</label><input v-model.number="st.recharge_bonus" type="number" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
      <div class="bh" @click="toggleAccordion('st_points')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_points}"></i> 积分设置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_points}">
        <div class="fr"><div class="fg"><label>每元购买赠送积分</label><input v-model.number="st.points_per_yuan" type="number" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
      <div class="bh" @click="toggleAccordion('st_shop')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.st_shop}"></i> 店铺设置</h3></div>
      <div class="bd" :class="{collapsed:!open.st_shop}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.shop_closed}" @click="st.shop_closed=!st.shop_closed"></div><label>店铺维护</label></div><div class="sw"><div class="toggle" :class="{on:st.maintenance_mode}" @click="st.maintenance_mode=!st.maintenance_mode"></div><label>全站维护</label></div></div>
        <div class="fr"><div class="fg" style="flex:100%"><label>维护公告</label><textarea v-model="st.closed_message"></textarea></div></div>
        <div class="hr"></div>
        <div class="fr"><div class="fg"><label>订单超时(分钟)</label><input v-model.number="st.order_timeout" type="number" /></div><div class="fg"><label>自动收货天数</label><input v-model.number="st.auto_receive_days" type="number" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.email_notify}" @click="st.email_notify=!st.email_notify"></div><label>邮件通知</label></div><div class="sw"><div class="toggle" :class="{on:st.sms_notify}" @click="st.sms_notify=!st.sms_notify"></div><label>短信通知</label></div></div>
        <div class="hr"></div>
        <div class="fr"><div class="fg"><label>默认展开分类</label><select v-model="st.default_category"><option value="0">不展开</option><option value="recommend">推荐</option><option v-for="c in ct" :key="c.id" :value="c.id">{{ c.name }}</option></select></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:st.commodity_recommend}" @click="st.commodity_recommend=!st.commodity_recommend"></div><label>首页商品推荐</label></div><div class="fg"><label>推荐分类名称</label><input v-model="st.commodity_name" placeholder="推荐" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveSt">保存设置</button></div>
      </div>
    </div>
    <div v-if="tb==='lt'" class="bk">
      <div class="bh" @click="toggle('lt_basic')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.lt_basic}"></i> 抽奖设置</h3></div>
      <div class="bd" :class="{collapsed:!open.lt_basic}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:lt.enabled}" @click="lt.enabled=!lt.enabled"></div><label>开启抽奖</label></div><div class="sw"><div class="toggle" :class="{on:lt.show_odds}" @click="lt.show_odds=!lt.show_odds"></div><label>显示概率</label></div><div class="sw"><div class="toggle" :class="{on:lt.anti_cheat}" @click="lt.anti_cheat=!lt.anti_cheat"></div><label>防小号</label></div></div>
        <div class="fr"><div class="fg"><label>单次抽奖价格</label><input v-model.number="lt.price" type="number" /></div><div class="fg"><label>每日免费次数</label><input v-model.number="lt.free_daily" type="number" /></div></div>
        <div class="fr"><div class="fg"><label>积分消耗</label><input v-model.number="lt.points_cost" type="number" /></div><div class="fg"><label>免费抽积分门槛</label><input v-model.number="lt.points_threshold" type="number" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveLt">保存</button></div>
      </div>
      <div class="bh" @click="toggle('lt_pool')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.lt_pool}"></i> 奖池配置</h3></div>
      <div class="bd" :class="{collapsed:!open.lt_pool}">
        <div class="fc" v-for="(item,i) in lt.pool" :key="i" style="margin-bottom:0.5rem">
          <div class="fr"><div class="fg"><label>商品ID</label><input v-model.number="item.product_id" type="number" /></div><div class="fg"><label>概率(%)</label><input v-model.number="item.odds" type="number" /></div><div class="fg"><label>权重</label><input v-model.number="item.weight" type="number" /></div></div>
          <button class="btn btn-dr btn-sm" @click="lt.pool.splice(i,1)">删除</button>
        </div>
        <button class="btn btn-a btn-sm" @click="lt.pool.push({product_id:0,odds:0,weight:1})">+ 添加奖项</button>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveLt">保存奖池</button></div>
      </div>
      <div class="bh" @click="toggle('lt_cool')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.lt_cool}"></i> 保底设置</h3></div>
      <div class="bd" :class="{collapsed:!open.lt_cool}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:lt.pity_enabled}" @click="lt.pity_enabled=!lt.pity_enabled"></div><label>开启保底</label></div><div class="fg"><label>保底次数</label><input v-model.number="lt.pity_count" type="number" /></div></div>
        <div class="fr"><div class="fg"><label>保底商品ID</label><input v-model.number="lt.pity_product_id" type="number" /></div><div class="fg"><label>保底概率(%)</label><input v-model.number="lt.pity_odds" type="number" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveLt">保存</button></div>
      </div>
    </div>
    <div v-if="tb==='py'" class="bk">
      <div class="bh" @click="toggle('py_general')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.py_general}"></i> 支付方式管理</h3></div>
      <div class="bd" :class="{collapsed:!open.py_general}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.alipay.enabled}" @click="pay.alipay.enabled=!pay.alipay.enabled"></div><label>支付宝</label></div><div class="fg"><label>AppID</label><input v-model="pay.alipay.app_id" placeholder="支付宝应用ID" /></div><div class="fg"><label>商户私钥</label><input v-model="pay.alipay.private_key" placeholder="商户私钥" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.wxpay.enabled}" @click="pay.wxpay.enabled=!pay.wxpay.enabled"></div><label>微信支付</label></div><div class="fg"><label>商户号</label><input v-model="pay.wxpay.mch_id" placeholder="微信支付商户号" /></div><div class="fg"><label>商户密钥</label><input v-model="pay.wxpay.key" placeholder="商户API密钥" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.qqpay.enabled}" @click="pay.qqpay.enabled=!pay.qqpay.enabled"></div><label>QQ钱包</label></div><div class="fg"><label>商户号</label><input v-model="pay.qqpay.mch_id" placeholder="QQ钱包商户号" /></div><div class="fg"><label>密钥</label><input v-model="pay.qqpay.key" placeholder="API密钥" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.shouqianba.enabled}" @click="pay.shouqianba.enabled=!pay.shouqianba.enabled"></div><label>收钱吧</label></div><div class="fg"><label>商户号</label><input v-model="pay.shouqianba.mch_id" placeholder="收钱吧商户号" /></div><div class="fg"><label>终端号</label><input v-model="pay.shouqianba.terminal_id" placeholder="收钱吧终端号" /></div><div class="fg"><label>密钥</label><input v-model="pay.shouqianba.key" placeholder="API密钥" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.maPay.enabled}" @click="pay.maPay.enabled=!pay.maPay.enabled"></div><label>码支付(一收米)</label></div><div class="fg"><label>商户号</label><input v-model="pay.maPay.mch_id" placeholder="码支付商户号" /></div><div class="fg"><label>密钥</label><input v-model="pay.maPay.key" placeholder="API密钥" /></div></div>
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:pay.usdt.enabled}" @click="pay.usdt.enabled=!pay.usdt.enabled"></div><label>USDT(TRC20)</label></div><div class="fg"><label>收款地址</label><input v-model="pay.usdt.address" placeholder="USDT收款地址" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="savePay">保存支付设置</button></div>
      </div>
      <div class="bh"><h3>充值订单记录</h3></div>
      <div class="bd tw">
        <table><thead><tr><th>订单号</th><th>用户</th><th>金额</th><th>支付方式</th><th>状态</th><th>创建时间</th></tr></thead>
        <tbody><tr v-for="r in rechargeRecords" :key="r.id">
          <td style="font-family:monospace">{{ r.order_no }}</td>
          <td>{{ r.user?.username||'N/A' }}</td>
          <td>¥{{ r.amount }}</td>
          <td>{{ r.method }}</td>
          <td><span class="bg" :class="r.status==='completed'?'yes':'wait'">{{ r.status==='completed'?'已完成':'待支付' }}</span></td>
          <td>{{ fm(r.created_at) }}</td>
        </tr></tbody></table>
      </div>
    </div>
    <div v-if="tb==='ev'" class="bk">
      <div class="bh" @click="toggle('ev_basic')"><h3><i class="fas fa-chevron-right chevron" :class="{rot:open.ev_basic}"></i> 活动设置</h3></div>
      <div class="bd" :class="{collapsed:!open.ev_basic}">
        <div class="fr"><div class="sw"><div class="toggle" :class="{on:ev.enabled}" @click="ev.enabled=!ev.enabled"></div><label>开启活动</label></div><div class="sw"><div class="toggle" :class="{on:ev.show_progress}" @click="ev.show_progress=!ev.show_progress"></div><label>显示进度条</label></div><div class="sw"><div class="toggle" :class="{on:ev.show_countdown}" @click="ev.show_countdown=!ev.show_countdown"></div><label>显示倒计时</label></div></div>
        <div class="fr"><div class="fg"><label>活动标题</label><input v-model="ev.banner_title" /></div><div class="fg"><label>活动描述</label><input v-model="ev.banner_desc" /></div></div>
        <div class="fr" style="margin-top:1rem"><button class="btn btn-p" @click="saveEv">保存</button></div>
      </div>
      <div class="bh"><h3>活动商品管理<button class="btn btn-p btn-sm" style="margin-left:1rem" @click="openEventProductModal()">+ 添加活动商品</button></h3></div>
      <div class="bd">
        <div v-if="eventProducts.length" class="tw">
          <table><thead><tr><th>ID</th><th>商品名称</th><th>价格</th><th>原价</th><th>库存</th><th>开始时间</th><th>结束时间</th><th>状态</th><th>操作</th></tr></thead>
          <tbody>
            <tr v-for="p in eventProducts" :key="p.id">
              <td>{{ p.id }}</td>
              <td>{{ p.name }}</td>
              <td>¥{{ p.price }}</td>
              <td>¥{{ p.original_price }}</td>
              <td>{{ p.card_key_count }}</td>
              <td>{{ fm(p.start_at) }}</td>
              <td>{{ fm(p.end_at) }}</td>
              <td><span class="bg" :class="p.is_active?'yes':'no'">{{ p.is_active?'启用':'禁用' }}</span></td>
              <td><div class="ac"><button class="btn btn-sm btn-a" @click="openEventProductModal(p)">编辑</button><button class="btn btn-sm btn-dr" @click="deleteEventProduct(p)">删除</button></div></td>
            </tr>
          </tbody></table>
        </div>
        <div v-else class="empty-state fancy"><h4>暂无活动商品</h4><p>点击上方按钮添加活动商品</p></div>
      </div>
    </div>
  </div>
</main>
<div v-if="showProductModal" class="modal-overlay" @click.self="closeProductModal">
  <div class="modal">
    <div class="modal-header">
      <h2>{{ editingProduct ? '编辑商品' : '添加商品' }}</h2>
      <button class="modal-close" @click="closeProductModal">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-section">
        <h3><i class="fas fa-info-circle"></i> 基本信息</h3>
        <div class="form-grid">
          <div class="fg"><label>商品名称 *</label><input v-model="productForm.name" placeholder="输入商品名称" /></div>
          <div class="fg"><label>短描述</label><input v-model="productForm.short_description" placeholder="简短描述" /></div>
          <div class="fg"><label>商品价格 *</label><input v-model.number="productForm.price" type="number" step="0.01" placeholder="0.00" /></div>
          <div class="fg"><label>原价(划线价)</label><input v-model.number="productForm.original_price" type="number" step="0.01" placeholder="不填则使用现价" /></div>
          <div class="fg"><label>商品分类</label><select v-model="productForm.category_id"><option :value="0">无分类</option><option v-for="c in ct" :key="c.id" :value="c.id">{{ c.name }}</option></select></div>
          <div class="fg"><label>商品类型</label><select v-model="productForm.type"><option value="normal">普通商品</option><option value="blindbox">盲盒</option></select></div>
        </div>
        <div style="margin-top:1rem"><label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">商品详细描述</label><textarea v-model="productForm.description" placeholder="输入商品详细描述..." style="min-height:100px"></textarea></div>
        <div style="margin-top:1rem"><label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">商品详情页内容</label><textarea v-model="productForm.content" placeholder="支持HTML富文本内容..." style="min-height:120px"></textarea></div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-tag"></i> 折扣与定价</h3>
        <div class="form-grid">
          <div class="fg"><label>折扣价(临时)</label><input v-model.number="productForm.discount_price" type="number" step="0.01" placeholder="限时折扣价" /></div>
          <div class="fg"><label>折扣开始</label><input v-model="productForm.discount_start" type="datetime-local" /></div>
          <div class="fg"><label>折扣结束</label><input v-model="productForm.discount_end" type="datetime-local" /></div>
          <div class="fg"><label>成本价(不显示)</label><input v-model.number="productForm.cost_price" type="number" step="0.01" placeholder="用于利润计算" /></div>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-truck"></i> 发货设置</h3>
        <div class="form-grid">
          <div class="fg"><label>发货方式</label><select v-model="productForm.delivery_type"><option value="card_key">卡密自动发货</option><option value="file">文件自动发货</option><option value="manual">手动发货</option></select></div>
          <div class="fg"><label>库存预警数量</label><input v-model.number="productForm.stock_warning" type="number" placeholder="库存低于此数提醒" /></div>
        </div>
        <div v-if="productForm.delivery_type==='file'" style="margin-top:1rem">
          <div class="file-upload-area" @click="$refs.fileInput.click()">
            <i class="fas fa-cloud-upload-alt" style="font-size:2rem;margin-bottom:0.5rem"></i>
            <p style="font-size:0.85rem;margin-bottom:0.25rem">点击上传文件，或拖拽文件到此处</p>
            <p style="font-size:0.75rem;color:var(--dim)">支持多文件上传，上传后会自动打包成ZIP</p>
            <input ref="fileInput" type="file" multiple @change="handleFileUpload" style="display:none" />
          </div>
          <div class="file-list" v-if="productFiles.length>0">
            <div class="file-item" v-for="(f,idx) in productFiles" :key="idx">
              <div class="file-info">
                <div class="file-icon"><i class="fas fa-file"></i></div>
                <div>
                  <div class="file-name">{{ f.name }}</div>
                  <div class="file-size">{{ f.size }}</div>
                </div>
              </div>
              <div class="file-action">
                <button class="btn btn-sm" style="background:var(--danger);border:none" @click="removeProductFile(idx)">
                  <i class="fas fa-trash"></i> 删除
                </button>
              </div>
            </div>
          </div>
          <div style="margin-top:1rem;display:flex;gap:0.5rem;align-items:center" v-if="productFiles.length>0">
            <button class="compress-btn" @click="compressFiles" v-if="editingProduct">
              <i class="fas fa-file-archive"></i> 生成ZIP压缩包
            </button>
            <div v-if="productForm.file_path" style="font-size:0.8rem;color:var(--dim)">
              <i class="fas fa-check-circle" style="color:var(--success)"></i> 已生成压缩包: {{ productForm.file_name }} ({{ productForm.file_size }})
            </div>
          </div>
          <div class="form-grid" style="margin-top:1rem">
            <div class="fg"><label>文件名称</label><input v-model="productForm.file_name" placeholder="显示给用户的文件名" /></div>
            <div class="fg"><label>文件路径</label><input v-model="productForm.file_path" placeholder="文件下载链接或路径" /></div>
            <div class="fg"><label>文件大小</label><input v-model="productForm.file_size" placeholder="例如: 2.5MB" /></div>
          </div>
        </div>
        <div v-if="productForm.delivery_type==='manual'" style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">自动发货内容</label>
          <textarea v-model="productForm.auto_delivery_content" placeholder="用户付款后自动发送的内容..." style="min-height:80px"></textarea>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-shopping-cart"></i> 购买限制</h3>
        <div class="form-grid">
          <div class="fg"><label>总购买限制(0不限)</label><input v-model.number="productForm.max_buy_limit" type="number" placeholder="0表示不限购" /></div>
          <div class="fg"><label>单用户限购(0不限)</label><input v-model.number="productForm.per_user_limit" type="number" placeholder="每个用户最多买" /></div>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-image"></i> 商品图片</h3>
        <div class="form-grid">
          <div style="flex:2">
            <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">图片URL</label>
            <input v-model="productForm.image_url" placeholder="输入图片URL或上传" />
          </div>
          <div style="flex:1">
            <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">预览</label>
            <div class="preview-box" :class="{'has-image':productForm.image_url}">
              <img v-if="productForm.image_url" :src="productForm.image_url" @error="productForm.image_url=''" />
              <span v-else><i class="fas fa-image" style="font-size:2rem;margin-bottom:0.5rem"></i><br>暂无图片</span>
            </div>
          </div>
        </div>
      </div>
      
      <div v-if="productForm.type==='blindbox'" class="form-section">
        <h3><i class="fas fa-dice"></i> 盲盒设置</h3>
        <div class="form-grid">
          <div class="fg"><label>盲盒名称</label><input v-model="productForm.blindbox_name" placeholder="盲盒系列名称" /></div>
          <div class="fg"><label>显示概率</label>
            <select v-model="productForm.show_odds"><option :value="true">显示</option><option :value="false">隐藏</option></select>
          </div>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-images"></i> 媒体设置</h3>
        <div class="form-grid">
          <div style="flex:2">
            <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">主图URL</label>
            <input v-model="productForm.image_url" placeholder="输入主图URL" />
          </div>
          <div style="flex:1">
            <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">预览</label>
            <div class="preview-box" :class="{'has-image':productForm.image_url}">
              <img v-if="productForm.image_url" :src="productForm.image_url" @error="productForm.image_url=''" />
              <span v-else><i class="fas fa-image" style="font-size:2rem;margin-bottom:0.5rem"></i><br>暂无图片</span>
            </div>
          </div>
        </div>
        <div style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">更多图片(多个URL用逗号分隔)</label>
          <input v-model="productForm.images" placeholder="URL1,URL2,URL3..." />
        </div>
        <div style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">视频URL(可选)</label>
          <input v-model="productForm.video_url" placeholder="商品视频链接" />
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-bookmark"></i> 商品标签</h3>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
          <div class="sw"><div class="toggle" :class="{on:productForm.is_featured}" @click="productForm.is_featured=!productForm.is_featured"></div><label>推荐商品</label></div>
          <div class="sw"><div class="toggle" :class="{on:productForm.is_hot}" @click="productForm.is_hot=!productForm.is_hot"></div><label>热卖中</label></div>
          <div class="sw"><div class="toggle" :class="{on:productForm.is_new}" @click="productForm.is_new=!productForm.is_new"></div><label>新品上架</label></div>
          <div class="sw"><div class="toggle" :class="{on:productForm.is_seckill}" @click="productForm.is_seckill=!productForm.is_seckill"></div><label>秒杀特价</label></div>
        </div>
        <div style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">自定义标签(多个用逗号分隔)</label>
          <input v-model="productForm.tags" placeholder="例如: 热卖, 限量, 独家" />
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-info-circle"></i> 购买须知</h3>
        <div style="margin-top:0.5rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">购买注意事项</label>
          <textarea v-model="productForm.buy_notice" placeholder="告诉用户购买前需要注意的事项..." style="min-height:70px"></textarea>
        </div>
        <div style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">售后说明</label>
          <textarea v-model="productForm.after_sale_notice" placeholder="告诉用户售后保障和退款说明..." style="min-height:70px"></textarea>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-search"></i> SEO与排序</h3>
        <div class="form-grid">
          <div class="fg"><label>SEO标题</label><input v-model="productForm.seo_title" placeholder="页面标题" /></div>
          <div class="fg"><label>SEO关键词</label><input v-model="productForm.seo_keywords" placeholder="关键词,关键词" /></div>
        </div>
        <div style="margin-top:1rem">
          <label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">SEO描述</label>
          <textarea v-model="productForm.seo_description" placeholder="搜索引擎摘要..." style="min-height:60px"></textarea>
        </div>
        <div style="margin-top:1rem" class="form-grid">
          <div class="fg"><label>排序权重</label><input v-model.number="productForm.sort_order" type="number" placeholder="数值越大越靠前" /></div>
        </div>
      </div>
      
      <div class="form-section">
        <h3><i class="fas fa-toggle-on"></i> 商品状态</h3>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
          <div class="sw"><div class="toggle" :class="{on:productForm.is_active}" @click="productForm.is_active=!productForm.is_active"></div><label>上架销售</label></div>
          <div class="sw"><div class="toggle" :class="{on:productForm.allow_comments}" @click="productForm.allow_comments=!productForm.allow_comments"></div><label>允许评论</label></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button v-if="editingProduct" class="btn btn-dr" @click="deleteProduct">删除</button>
      <div style="flex:1"></div>
      <button class="btn btn-a" @click="closeProductModal">取消</button>
      <button class="btn btn-p" @click="saveProduct">{{ editingProduct ? '保存修改' : '创建商品' }}</button>
    </div>
  </div>
</div>

<!-- 补货弹窗 -->
<div v-if="showRestockModal" class="modal-overlay" @click.self="closeRestockModal">
  <div class="modal" style="max-width:500px">
    <div class="modal-header">
      <h2><i class="fas fa-boxes"></i> 批量补货</h2>
      <button class="modal-close" @click="closeRestockModal">&times;</button>
    </div>
    <div class="modal-body">
      <div class="restock-section" style="margin:0;padding:0;border:none">
        <div class="restock-info">
          <div class="restock-product">
            <div style="width:50px;height:50px;background:var(--bg3);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1.5rem">
              📦
            </div>
            <div class="restock-product-info">
              <h4>{{ restockProduct?.name }}</h4>
              <span style="font-size:0.85rem;color:var(--dim)">ID: {{ restockProduct?.id }}</span>
            </div>
          </div>
          <div class="restock-stats">
            <div class="restock-stat">
              <div class="num" :style="{color: getStockClass(restockProduct)==='empty'?'var(--danger)':getStockClass(restockProduct)==='low'?'var(--warning)':'var(--success)'}">
                {{ restockProduct?.available_stock||0 }}
              </div>
              <div class="label">剩余库存</div>
            </div>
            <div class="restock-stat">
              <div class="num">{{ restockProduct?.total_stock||0 }}</div>
              <div class="label">总库存</div>
            </div>
          </div>
        </div>
        
        <div class="restock-form">
          <div>
            <label style="display:block;font-size:0.85rem;color:var(--dim);margin-bottom:0.5rem">📝 输入卡密（一行一个）</label>
            <textarea v-model="restockKeys" placeholder="例如：
ABCD-1234-EFGH-5678
WXYZ-9876-IJKL-5432
MNOP-1111-QRST-2222" style="min-height:150px;font-family:monospace;font-size:0.9rem"></textarea>
          </div>
          
          <div class="quick-buttons" style="flex-direction:column;gap:0.75rem">
            <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">
              <span style="font-size:0.85rem;color:var(--dim)">🚀 快速生成：</span>
              <input v-model.number="quickGenerateCount" type="number" min="1" max="1000" placeholder="数量" style="width:100px;padding:0.4rem;font-size:0.9rem" />
              <button class="quick-btn" @click="generateQuickKeys" :disabled="!quickGenerateCount || quickGenerateCount < 1">
                <i class="fas fa-magic"></i> 生成卡密
              </button>
            </div>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
              <button class="quick-btn" @click="generateAndAddKeys(10)">🎲 +10个</button>
              <button class="quick-btn" @click="generateAndAddKeys(50)">🎲 +50个</button>
              <button class="quick-btn" @click="generateAndAddKeys(100)">🎲 +100个</button>
              <button class="quick-btn" @click="generateAndAddKeys(500)">🎲 +500个</button>
            </div>
          </div>
          
          <div v-if="restockKeys" style="padding:0.75rem;background:var(--bg3);border-radius:6px;font-size:0.85rem">
            <div style="display:flex;justify-content:space-between;margin-bottom:0.5rem">
              <span>本次将添加：</span>
              <strong style="color:var(--success)">{{ getKeyCount() }} 个卡密</strong>
            </div>
            <div style="display:flex;justify-content:space-between">
              <span>补货后总库存：</span>
              <strong style="color:var(--primary)">{{ (restockProduct?.available_stock||0) + getKeyCount() }}</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-a" @click="closeRestockModal">取消</button>
      <button class="btn btn-p" @click="confirmRestock" :disabled="!restockKeys.trim()">
        <i class="fas fa-check"></i> 确认补货
      </button>
    </div>
  </div>
</div>
<div v-if="showEventProductModal" class="modal-overlay" @click.self="closeEventProductModal">
  <div class="modal">
    <div class="modal-header">
      <h2>{{ editingEventProduct ? '编辑活动商品' : '添加活动商品' }}</h2>
      <button class="modal-close" @click="closeEventProductModal">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-section">
        <h3><i class="fas fa-info-circle"></i> 基本信息</h3>
        <div class="form-grid">
          <div class="fg"><label>商品名称 *</label><input v-model="eventProductForm.name" placeholder="输入商品名称" /></div>
          <div class="fg"><label>商品价格 *</label><input v-model.number="eventProductForm.price" type="number" step="0.01" placeholder="0.00" /></div>
          <div class="fg"><label>原价(划线价)</label><input v-model.number="eventProductForm.original_price" type="number" step="0.01" placeholder="不填则使用现价" /></div>
          <div class="fg"><label>折扣价</label><input v-model.number="eventProductForm.discount_price" type="number" step="0.01" placeholder="活动折扣价" /></div>
        </div>
        <div style="margin-top:1rem"><label style="display:block;font-size:0.78rem;color:var(--dim);margin-bottom:0.25rem">商品描述</label><textarea v-model="eventProductForm.description" placeholder="输入商品描述..." style="min-height:80px"></textarea></div>
      </div>
      <div class="form-section">
        <h3><i class="fas fa-calendar"></i> 活动时间</h3>
        <div class="form-grid">
          <div class="fg"><label>开始时间</label><input v-model="eventProductForm.start_at" type="datetime-local" /></div>
          <div class="fg"><label>结束时间</label><input v-model="eventProductForm.end_at" type="datetime-local" /></div>
        </div>
      </div>
      <div class="form-section">
        <h3><i class="fas fa-cog"></i> 其他设置</h3>
        <div class="form-grid">
          <div class="fg"><label>图片URL</label><input v-model="eventProductForm.image_url" placeholder="输入图片URL" /></div>
          <div class="fg"><label>排序权重</label><input v-model.number="eventProductForm.sort_order" type="number" placeholder="数值越大越靠前" /></div>
          <div class="fg"><label>库存</label><input v-model.number="eventProductForm.stock" type="number" placeholder="-1表示不限库存" /></div>
        </div>
        <div style="display:flex;gap:1rem;margin-top:1rem">
          <div class="sw"><div class="toggle" :class="{on:eventProductForm.is_active}" @click="eventProductForm.is_active=!eventProductForm.is_active"></div><label>上架销售</label></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-a" @click="closeEventProductModal">取消</button>
      <button class="btn btn-p" @click="saveEventProduct">{{ editingEventProduct ? '保存修改' : '添加商品' }}</button>
    </div>
  </div>
</div>
</template>
<div class="tc"><div v-for="t in ts" :key="t.id" class="tt" :class="t.ty">{{ t.msg }}</div></div>
</div>
<script>
const{createApp,ref,computed,watch}=Vue

function getCookie(name){
  const v=document.cookie.match('(^|; )'+name+'=([^;]*)');
  return v?decodeURIComponent(v[2]):null
}

const LS_TOKEN = (()=>{try{return localStorage.getItem('token')}catch(e){return null}})()
const COOKIE_TOKEN = getCookie('admin_token')

createApp({
setup(){
const token=ref(LS_TOKEN||COOKIE_TOKEN||'')
const msg=ref('验证中...'),tb=ref('db'),un=ref(''),ts=ref([]),rd=ref(false),ready=ref(false)

function tst(m,ty){ts.value.push({id:Date.now(),msg:m,ty});setTimeout(()=>ts.value.splice(0,1),3000)}

const api={
  tk:token.value,
  async rq(m,p,b){
    const h={'Content-Type':'application/json'}
    if(this.tk)h['Authorization']='Bearer '+this.tk
    const r=await fetch(p,{method:m,headers:h,body:b?JSON.stringify(b):undefined})
    if(r.status==401){
      try{localStorage.removeItem('token')}catch(e){}
      document.cookie='admin_token=;path=/;max-age=0'
      window.location.href='/admin-login'
      throw new Error('登录已过期')
    }
    if(r.status==403){
      try{localStorage.removeItem('token')}catch(e){}
      document.cookie='admin_token=;path=/;max-age=0'
      window.location.href='/admin-login'
      throw new Error('没有权限')
    }
    const d=await r.json()
    if(!r.ok)throw new Error(d.detail||d.error||'请求失败')
    return d
  }
}
function initParticles(theme='cyberpunk'){
  const canvas=document.getElementById('particle-canvas')
  if(!canvas)return
  const ctx=canvas.getContext('2d')
  let w,h,particles=[],animationId
  const resize=()=>{w=canvas.width=window.innerWidth;h=canvas.height=window.innerHeight}
  resize();window.addEventListener('resize',resize)
  
  function getParticleConfig(t){
    switch(t){
      case'simple':return{count:40,minR:3,maxR:6,speed:0.3,color:'rgba(59,130,246,1)',lineDist:120,attract:true}
      case'cute':return{count:30,minR:8,maxR:15,speed:0.2,color:'rgba(255,105,180,1)',lineDist:100,attract:false,hearts:true}
      case'anime':return{count:50,minR:2,maxR:5,speed:0.4,color:'rgba(255,107,157,1)',lineDist:100,attract:false}
      default:return{count:80,minR:0.5,maxR:2.5,speed:0.5,color:'rgba(0,240,255,1)',lineDist:150,attract:false}
    }
  }
  
  const config=getParticleConfig(theme)
  for(let i=0;i<config.count;i++){
    particles.push({
      x:Math.random()*w,y:Math.random()*h,
      vx:(Math.random()-0.5)*config.speed,vy:(Math.random()-0.5)*config.speed,
      r:Math.random()*(config.maxR-config.minR)+config.minR,
      alpha:Math.random()*0.5+0.3,heart:config.hearts?Math.random()>0.5:false
    })
  }
  
  function drawHeart(x,y,r,color,alpha){
    ctx.save();ctx.translate(x,y);ctx.fillStyle=color.replace('1)',alpha+')');
    ctx.beginPath();
    ctx.moveTo(0,r*0.3);
    ctx.bezierCurveTo(-r*0.5,-r*0.3,-r,r*0.1,-r*0.5,r*0.6);
    ctx.bezierCurveTo(-r*0.2,r*r*0.8,r*0.2,r*r*0.8,r*0.5,r*0.6);
    ctx.bezierCurveTo(r,r*0.1,r*0.5,-r*0.3,0,r*0.3);
    ctx.fill();ctx.restore();
  }
  
  function draw(){
    if(animationId)cancelAnimationFrame(animationId)
    ctx.clearRect(0,0,w,h)
    
    for(const p of particles){
      p.x+=p.vx;p.y+=p.vy
      if(p.x<0)p.x=w;if(p.x>w)p.x=0
      if(p.y<0)p.y=h;if(p.y>h)p.y=0
      
      if(config.hearts&&p.heart){
        drawHeart(p.x,p.y,p.r,config.color,p.alpha)
      }else{
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2)
        ctx.fillStyle=config.color.replace('1)',p.alpha+')');ctx.fill()
        ctx.shadowBlur=10;ctx.shadowColor=config.color;ctx.shadowBlur=0
      }
    }
    
    for(let i=0;i<particles.length;i++)
      for(let j=i+1;j<particles.length;j++){
        const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,dist=Math.sqrt(dx*dx+dy*dy)
        if(dist<config.lineDist){
          const alpha=0.15*(1-dist/config.lineDist)
          ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y)
          ctx.strokeStyle=config.color.replace('1)',alpha+')');ctx.lineWidth=1;ctx.stroke()
          
          if(config.attract){
            const force=(config.lineDist-dist)/config.lineDist*0.01
            particles[i].vx+=dx*force;particles[i].vy+=dy*force
            particles[j].vx-=dx*force;particles[j].vy-=dy*force
          }
        }
      }
    animationId=requestAnimationFrame(draw)
  }
  draw()
}
// 先从window._initialTheme获取（由内联脚本设置）
const currentTheme=ref(window._initialTheme||'cyberpunk')
initParticles(currentTheme.value)

function applyTheme(theme){
  document.body.className='';
  if(theme!=='cyberpunk')document.body.classList.add('theme-'+theme);
  localStorage.setItem('adminTheme',theme);
}

// 保存主题到后端
let savingTheme=false
async function changeTheme(theme){
  if(savingTheme)return
  savingTheme=true
  currentTheme.value=theme
  document.body.className=''
  if(theme!=='cyberpunk')document.body.classList.add('theme-'+theme)
  initParticles(theme)
  // 保存到后端
  try{
    const h={'Content-Type':'application/json'}
    if(token.value)h['Authorization']='Bearer '+token.value
    await fetch('/api/admin/site/theme',{
      method:'POST',
      headers:h,
      body:JSON.stringify({theme:theme})
    })
    tst('主题保存成功','ok')
  }catch(e){
    tst('保存失败: '+e.message,'er')
  }
  savingTheme=false
}
const ps=ref([]),or=ref([]),us=ref([]),cs=ref([]),ct=ref([]),ks=ref([]),da=ref({})
const kp=ref(0),kt=ref(''),spf=ref(false),eid=ref(0),pf=ref({name:'',description:'',price:0,category_id:0,type:'normal',delivery_type:'card_key'})
const showProductModal=ref(false),editingProduct=ref(null)
const productForm=ref({
  name:'',short_description:'',description:'',content:'',
  price:0,original_price:null,cost_price:null,discount:0,
  discount_price:null,discount_start:'',discount_end:'',
  category_id:0,image_url:'',images:'',video_url:'',
  featured:false,is_hot:false,is_new:false,is_recommend:false,is_seckill:false,
  type:'normal',stock:-1,stock_warning:10,max_buy_limit:0,per_user_limit:0,
  delivery_type:'card_key',file_path:'',file_name:'',file_size:'',auto_delivery_content:'',
  is_active:true,sort_order:0,seo_title:'',seo_keywords:'',seo_description:'',
  tags:'',buy_notice:'',after_sale_notice:'',allow_comments:true
})
const refreshingStock=ref(false),stockUpdateTime=ref({}),stockPollInterval=ref(null)
const showRestockModal=ref(false),restockProduct=ref(null),restockKeys=ref(''),quickGenerateCount=ref(100)
const productFiles=ref([])
const recommends=ref([])
const showAddProductModal=ref(false),currentRecommendCategory=ref(null)
const eventProducts=ref([]),showEventProductModal=ref(false),editingEventProduct=ref(null)
const eventProductForm=ref({
  name:'',description:'',price:0,original_price:null,discount_price:null,
  start_at:'',end_at:'',image_url:'',sort_order:0,stock:-1,is_active:true
})
function openProductModal(p=null){
  productFiles.value=[];
  if(p){
    editingProduct.value=p.id;
    productForm.value={
      name:p.name||'',short_description:p.short_description||'',description:p.description||'',content:p.content||'',
      price:p.price||0,original_price:p.original_price,cost_price:p.cost_price,discount:p.discount||0,
      discount_price:p.discount_price,discount_start:p.discount_start||'',discount_end:p.discount_end||'',
      category_id:p.category_id||0,image_url:p.image_url||'',images:p.images||'',video_url:p.video_url||'',
      featured:p.featured||false,is_hot:p.is_hot||false,is_new:p.is_new||false,is_recommend:p.is_recommend||false,is_seckill:p.is_seckill||false,
      type:p.type||'normal',stock:p.stock||-1,stock_warning:p.stock_warning||10,max_buy_limit:p.max_buy_limit||0,per_user_limit:p.per_user_limit||0,
      delivery_type:p.delivery_type||'card_key',file_path:p.file_path||'',file_name:p.file_name||'',file_size:p.file_size||'',auto_delivery_content:p.auto_delivery_content||'',
      is_active:p.is_active!==false,sort_order:p.sort_order||0,seo_title:p.seo_title||'',seo_keywords:p.seo_keywords||'',seo_description:p.seo_description||'',
      tags:p.tags||'',buy_notice:p.buy_notice||'',after_sale_notice:p.after_sale_notice||'',allow_comments:p.allow_comments!==false
    };
    if(p.id)loadProductFiles(p.id);
  }else{
    editingProduct.value=null;
    productForm.value={
      name:'',short_description:'',description:'',content:'',
      price:0,original_price:null,cost_price:null,discount:0,
      discount_price:null,discount_start:'',discount_end:'',
      category_id:0,image_url:'',images:'',video_url:'',
      featured:false,is_hot:false,is_new:false,is_recommend:false,is_seckill:false,
      type:'normal',stock:-1,stock_warning:10,max_buy_limit:0,per_user_limit:0,
      delivery_type:'card_key',file_path:'',file_name:'',file_size:'',auto_delivery_content:'',
      is_active:true,sort_order:0,seo_title:'',seo_keywords:'',seo_description:'',
      tags:'',buy_notice:'',after_sale_notice:'',allow_comments:true
    }
  }
  showProductModal.value=true
}
async function loadProductFiles(pid){
  try{
    const files=await api.rq('GET','/api/admin/products/'+pid+'/files');
    productFiles.value=files||[];
  }catch(e){
    console.error(e);
  }
}
async function handleFileUpload(event){
  if(!editingProduct.value){tst('请先保存商品后再上传文件','er');return;}
  const files=event.target.files;
  if(!files.length)return;
  for(let i=0;i<files.length;i++){
    const file=files[i];
    const formData=new FormData();
    formData.append('file',file);
    try{
      const h={}
      if(token.value)h['Authorization']='Bearer '+token.value
      const res=await fetch('/api/admin/products/'+editingProduct.value+'/files',{
        method:'POST',
        headers:h,
        body:formData
      });
      const data=await res.json();
      if(data.list)productFiles.value=data.list;
      tst('文件上传成功','ok');
    }catch(e){
      tst('文件上传失败: '+e.message,'er');
    }
  }
}
function removeProductFile(idx){
  if(!editingProduct.value)return;
  const file=productFiles.value[idx];
  if(!file.id)return;
  api.rq('DELETE','/api/admin/products/'+editingProduct.value+'/files/'+file.id).then(()=>{
    productFiles.value.splice(idx,1);
    tst('文件已删除','ok');
  }).catch(e=>tst(e.message,'er'));
}
function compressFiles(){
  if(!editingProduct.value){tst('请先保存商品','er');return;}
  if(productFiles.value.length===0){tst('请先上传文件','er');return;}
  api.rq('POST','/api/admin/products/'+editingProduct.value+'/compress').then(d=>{
    productForm.value.file_path=d.zip_path;
    productForm.value.file_name=d.file_name;
    productForm.value.file_size=d.file_size;
    tst('压缩包生成成功','ok');
  }).catch(e=>tst(e.message,'er'));
}
function addRecommendCategory(){
  recommends.value.push({id:null,category_name:'',category_id:0,product_ids:[],products:[],sort_order:0});
}
async function saveRecommend(rc){
  try{
    const data={id:rc.id,category_name:rc.category_name,category_id:rc.category_id,product_ids:rc.product_ids,sort_order:rc.sort_order};
    const res=await api.rq('POST','/api/admin/recommends',data);
    if(!rc.id&&res.id)rc.id=res.id;
    tst('保存成功','ok');
    loadRecommends();
  }catch(e){tst(e.message,'er');}
}
async function deleteRecommend(id){
  if(!id){
    const idx=recommends.value.findIndex(r=>r.id===id);
    if(idx>-1)recommends.value.splice(idx,1);
    return;
  }
  if(!confirm('确定删除此推荐分类？'))return;
  try{
    await api.rq('DELETE','/api/admin/recommends/'+id);
    const idx=recommends.value.findIndex(r=>r.id===id);
    if(idx>-1)recommends.value.splice(idx,1);
    tst('删除成功','ok');
  }catch(e){tst(e.message,'er');}
}
function toggleProductInRecommend(rc,productId){
  if(!rc.product_ids)rc.product_ids=[];
  const idx=rc.product_ids.indexOf(productId);
  if(idx>-1)rc.product_ids.splice(idx,1);
  else rc.product_ids.push(productId);
}
function openAddProductModal(rc){
  currentRecommendCategory.value=rc;
  showAddProductModal.value=true;
}
async function loadRecommends(){
  try{
    const data=await api.rq('GET','/api/admin/recommends');
    recommends.value=data||[];
  }catch(e){console.error(e);}
}
function closeProductModal(){showProductModal.value=false;editingProduct.value=null}
function saveProduct(){const d=productForm.value;if(!d.name){tst('请输入商品名称','er');return}if(d.price<=0){tst('请输入有效的价格','er');return}const fn=editingProduct.value?api.rq('PUT','/api/admin/products/'+editingProduct.value,d):api.rq('POST','/api/admin/products',d);fn.then(()=>{closeProductModal();api.rq('GET','/api/products').then(r=>ps.value=r.products||[]);tst(editingProduct.value?'商品已更新':'商品已创建','ok')}).catch(e=>tst(e.message,'er'))}
function deleteProduct(){if(!editingProduct.value)return;if(!confirm('确定删除此商品？此操作不可恢复！'))return;api.rq('DELETE','/api/admin/products/'+editingProduct.value).then(()=>{closeProductModal();api.rq('GET','/api/products').then(r=>ps.value=r.products||[]);tst('商品已删除','ok')}).catch(e=>tst(e.message,'er'))}
function getStockClass(p){const available=p.available_stock||0;const total=p.total_stock||0;if(available===0)return'empty';if(available<=5)return'low';if(available<=total*0.3)return'medium';return'high'}
function getStockStatus(p){const available=p.available_stock||0;const warning=p.stock_warning||10;if(available===0)return'empty';if(available<=warning)return'low';return'available'}
function getStockText(p){const available=p.available_stock||0;if(available===0)return'已售罄';const warning=p.stock_warning||10;if(available<=warning)return'库存紧张';return'有货'}
function refreshAllStocks(){if(refreshingStock.value)return;refreshingStock.value=true;api.rq('GET','/api/products').then(r=>{const oldStocks={};ps.value.forEach(p=>oldStocks[p.id]=p.available_stock);ps.value=r.products||[];ps.value.forEach(p=>{if(oldStocks[p.id]!==undefined&&oldStocks[p.id]!==p.available_stock){stockUpdateTime.value[p.id]=Date.now();setTimeout(()=>{delete stockUpdateTime.value[p.id]},1000)}});refreshingStock.value=false}).catch(()=>{refreshingStock.value=false})}
function startStockPolling(){if(stockPollInterval.value)return;stockPollInterval.value=setInterval(()=>{if(tb.value==='pd'&&!showProductModal.value&&!showRestockModal.value){refreshAllStocks()}},5000)}
function stopStockPolling(){if(stockPollInterval.value){clearInterval(stockPollInterval.value);stockPollInterval.value=null}}
function openRestockModal(p){restockProduct.value=p;restockKeys.value='';quickGenerateCount.value=100;showRestockModal.value=true}
function closeRestockModal(){showRestockModal.value=false;restockProduct.value=null;restockKeys.value=''}
function getKeyCount(){if(!restockKeys.value)return 0;return restockKeys.value.split('\n').filter(k=>k.trim()).length}
function generateKey(){const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';let key='';for(let i=0;i<4;i++){if(i>0)key+='-';for(let j=0;j<4;j++){key+=chars.charAt(Math.floor(Math.random()*chars.length))}}return key}
function generateKeys(count){let keys=[];for(let i=0;i<count;i++){keys.push(generateKey())}return keys}
function generateQuickKeys(){const count=quickGenerateCount.value||100;const keys=generateKeys(count);restockKeys.value=(restockKeys.value?restockKeys.value+'\n':'')+keys.join('\n')}
function generateAndAddKeys(count){const keys=generateKeys(count);restockKeys.value=(restockKeys.value?restockKeys.value+'\n':'')+keys.join('\n')}
function confirmRestock(){if(!restockProduct.value){tst('请选择商品','er');return}let keys=[];if(restockKeys.value.trim()){keys=restockKeys.value.split('\n').filter(k=>k.trim())}if(keys.length===0){tst('请输入卡密或使用快速生成','er');return}const data={product_id:restockProduct.value.id,keys:restockKeys.value};api.rq('POST','/api/admin/cardkeys/import',data).then(()=>{closeRestockModal();refreshAllStocks();tst(`成功添加 ${keys.length} 个卡密`,'ok')}).catch(e=>tst(e.message,'er'))}

