function toggle(k){open.value[k]=!open.value[k]}
function toggleAccordion(key){
  // 手风琴效果：只展开当前项，收起其他项
  Object.keys(open.value).forEach(k => {
    if(k.startsWith('st_') || k.startsWith('lt_') || k.startsWith('ev_')){
      if(k === key){
        open.value[k] = true
      } else {
        open.value[k] = false
      }
    }
  })
}
